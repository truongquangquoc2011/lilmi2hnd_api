generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ImportStatus {
  PENDING
  RECEIVED
}
enum OrderStatus {
  TRANSFER    // Đã Chuyển Khoản
  PACKED      // Đã gói đơn
  SENT        // Đã gửi đơn
  COMPLETED   // Hoàn thành
  UNPAID      // Chưa thanh toán
  CASH        // Tiền mặt
}

enum ShippingStatus {
  SHIPPING    // Ship
  PICKUP      // Qua Lấy
  KEEP        // Keep bill
}
model Import {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  provider  String  
  

  baleName  String?  
  price     String?
  phone     String?
  note      String?
  
  isPaid    Boolean  @default(false)
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  stt              Int      @default(0)
  customerName     String
  orderContent     String?
  itemImages       String[] @default([])
  totalPrice       String?  @default("0")
  status           OrderStatus     @default(UNPAID)
  shipping         ShippingStatus  @default(SHIPPING)
  address          String?
  note             String?
  shippingMessage  String?
  trackingCode     String?
  shippingFee      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  image         String
  isOutOfStock  Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}